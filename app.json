{
  "expo": {
    "name": "OwoTrack",
    "slug": "owo-track",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "owotrack",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.owotrack.app"
    },
    "android": {
      "package": "com.owotrack.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1A6B3C"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 220,
          "backgroundColor": "#1A6B3C",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#1A6B3C"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow OwoTrack to record your voice for entering sales quickly."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "environment": "production",
      "router": {},
      "eas": {
        "projectId": "362da4b1-8941-47a5-9f01-5a7c9601415e"
      }
    }
  }
}
